meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{identityUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "admin@clinica-demo.com",
    "password": "Password1"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.access_token);
  }
}
