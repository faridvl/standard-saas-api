datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"] 
}

model Patient {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  firstName    String
  lastName     String
  phone        String?
  address      String?
  birthDate    DateTime
  email        String?
  gender              String?
  bloodType           String?
  linkedProductUuid   String?
  documentId          String?
  occupation          String?
  sede                String?

  tenantId     Int
  tenantUuid   String
  createdBy    String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments    Appointment[]
  medicalControls MedicalControl[]
  background      PatientBackground?
  maintenances    Maintenance[]

  @@index([tenantId])
}

model PatientBackground {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  patientUuid   String   @unique
  earInfections Boolean  @default(false)
  nasalSurgery  Boolean  @default(false)
  throatSurgery Boolean  @default(false)
  earSurgery    Boolean  @default(false)
  diabetes      Boolean  @default(false)
  cholesterol   Boolean  @default(false)
  highPressure  Boolean  @default(false)
  allergies     Boolean  @default(false)
  rhinitis      Boolean  @default(false)
  vertigo       Boolean  @default(false)
  tinnitus      Boolean  @default(false)
  headacheNoise Boolean  @default(false)
  cloggedEar    Boolean  @default(false)
  notes         String?
  updatedAt     DateTime @updatedAt

  patient       Patient  @relation(fields: [patientUuid], references: [uuid])
}

model Maintenance {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  patientUuid       String
  tenantUuid        String
  performedBy       String
  performedAt       DateTime  @default(now())
  description       String    @db.Text
  nextMaintenanceAt DateTime?
  deviceUuid        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient           Patient   @relation(fields: [patientUuid], references: [uuid])

  @@index([patientUuid])
  @@index([tenantUuid])
  @@index([nextMaintenanceAt])
}

model MedicalControl {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  patientUUID     String
  userUUID        String
  tenantUUID      String
  appointmentUUID String?  @unique 
  speciality      String
  findings        Json
  diagnosis       String   @db.Text
  followUp        Json?
  schemaVersion   Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  patient         Patient      @relation(fields: [patientUUID], references: [uuid])
  appointment     Appointment? @relation(fields: [appointmentUUID], references: [uuid])

  @@index([patientUUID])
  @@index([tenantUUID])
}

model AppointmentType {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name        String
  duration    Int?
  color       String?
  speciality  String?
  tenantUUID  String

  appointments Appointment[]

  @@index([tenantUUID])
}

model Appointment {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique @default(uuid())
  patientUUID       String
  userUUID          String          
  tenantUUID        String
  typeUUID          String
  speciality        String
  status            String          
  date              DateTime        
  startTime         DateTime        
  endTime           DateTime        
  notes             String?         
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relaciones 
  patient           Patient         @relation(fields: [patientUUID], references: [uuid])
  appointmentType   AppointmentType @relation(fields: [typeUUID], references: [uuid])
  medicalControl    MedicalControl? 

  @@index([patientUUID])
  @@index([tenantUUID])
  @@index([userUUID])
}

model ClinicalTemplate {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  tenantUuid  String
  name        String
  speciality  String
  fields      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  tenantUuid   String  
  
  sku          String   @unique
  name         String
  model        String?
  description  String?  
  
  price        Decimal  @default(0.00) @db.Decimal(15, 2)
  currentStock Int      @default(0) @map("current_stock")
  minStock     Int      @default(5) @map("min_stock")
  cabysCode    String?  @map("cabys_code")
  
  isActive     Boolean  @default(true) @map("is_active")
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  speciality   String? 

  @@index([tenantUuid])
  @@index([sku])
}